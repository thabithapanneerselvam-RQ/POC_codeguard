          ],
          "fixes": [
            {
              "description": {
                "text": "By applying an HTML escaping function (e.g., `escapeHtml` from a library like `escape-goat`) to the `query` parameter before it's rendered in the HTML response, special characters (`<`, `>`, `&`, `\"`, `'`) are converted into their corresponding HTML entities. This ensures the browser interprets the user-supplied input as plain text rather than active HTML or JavaScript, effectively neutralizing XSS attacks."
              },
              "artifactChanges": [
                {
                  "artifactLocation": {
                    "uri": "src/test-vuln-2.js",
                    "uriBaseId": "%SRCROOT%"
