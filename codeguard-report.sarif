                      },
                      "insertedContent": {
                        "text": "const helmet = require('helmet'); // Add this line at the top of your file\nconst app = express()\napp.use(helmet()) // Use Helmet middleware to set security headers"
                      }
                    }
                  ]
                }
              ]
            }
